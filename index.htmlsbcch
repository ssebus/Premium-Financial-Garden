    { value: 20.00, type: "bill", bg: "linear-gradient(135deg, #93c5fd, #60a5fa, #3b82f6)", border: "#1d4ed8" },
    { value: 10.00, type: "bill", bg: "linear-gradient(135deg, #fca5a5, #f87171, #ef4444)", border: "#b91c1c" },
