function breakAmountIntoDenominations(amount) {
    let remaining = Math.round(amount * 100) / 100;
    let list = [];
    for (let denom of EURO_DENOMINATIONS) {
        while (remaining >= denom.value - 0.005) {
            list.push({ ...denom });
            remaining = Math.round((remaining - denom.value) * 100) / 100;
        }
    }
    return list;
}

function startAtmInteraction() {
    const t = translations[data.lang];
    const amount = parseFloat(document.getElementById("atmAmount").value);
    const reason = document.getElementById("atmReason").value;

    if (isNaN(amount) || amount <= 0) return;
    if (atmMode === "withdraw" && amount > data.balance) {
        alert(t.alertNoMoney);
        return;
    }

    totalTargetAmount = amount;
    remainingAmount = amount;
    pendingReason = reason;
    currentDenominationsList = breakAmountIntoDenominations(amount);
    currentDenominationIndex = 0;
    isAiBotRunning = false;

    document.getElementById("atmSetupStage").style.display = "none";
    document.getElementById("atmInteractiveStage").style.display = "block";
    
    document.getElementById("aiBotBtn").style.opacity = "1";
    document.getElementById("aiBotBtn").disabled = false;
    document.getElementById("atmAbortBtn").style.display = "inline-block";
    document.getElementById("atmTopCloseBtn").style.display = "inline-block";

    processNextDenomination();
}

function resetAtmStage() {
    if(isAiBotRunning) return;
    document.getElementById("atmSetupStage").style.display = "block";
    document.getElementById("atmInteractiveStage").style.display = "none";
}

function processNextDenomination() {
    const t = translations[data.lang];
    const dispenser = document.getElementById("moneyDispenser");
    const targetSlot = document.getElementById("atmSlotTarget");
    const instText = document.getElementById("atmInstructionText");
    const screenStatus = document.getElementById("atmScreenStatus");
    const screenRemaining = document.getElementById("atmScreenRemaining");

    dispenser.innerHTML = "";
    targetSlot.innerHTML = "";

    if (currentDenominationIndex >= currentDenominationsList.length) {
        executeFinalTransaction();
        return;
    }

    const currentItem = currentDenominationsList[currentDenominationIndex];
    screenRemaining.innerText = `${t.scrRemaining}${remainingAmount.toFixed(2)} €`;
    const progressText = `${currentDenominationIndex + 1}${t.scrOf}${currentDenominationsList.length})`;
    
    if(isAiBotRunning) {
        screenStatus.innerText = t.aiBotRunning;
        instText.innerText = "⚡ AI-BOT...";
    } else {
        if (atmMode === "deposit") {
            screenStatus.innerText = `${t.scrDepositStatus}${progressText}`;
            instText.innerText = t.atmDragInst;
        } else {
            screenStatus.innerText = `${t.scrWithdrawStatus}${progressText}`;
            instText.innerText = t.atmPrintInst;
        }
    }

    // Tworzenie kontenera pieniążka
    const moneyEl = document.createElement("div");
    moneyEl.className = "draggable-money";

    let labelValue = currentItem.value >= 1 ? `${currentItem.value.toFixed(0)}` : `${Math.round(currentItem.value * 100)}`;
    let labelUnit = currentItem.value >= 1 ? `EURO` : `CENT`;

    if (currentItem.type === "bill") {
        moneyEl.innerHTML = `
            <div class="real-bill" style="background: ${currentItem.bg}; border-color: ${currentItem.border};">
                <div class="bill-center-value">${labelValue}</div>
                <div class="bill-bottom-text">${labelValue} ${labelUnit}</div>
            </div>
        `;
    } else {
        let coinClass = "real-coin";
        if (currentItem.style === "silver-gold" || currentItem.style === "silver") {
            coinClass += " silver";
        } else if (currentItem.style === "bronze") {
            coinClass += " !bg-gradient-to-br !from-amber-700 !to-amber-900 !border-amber-950 !color-amber-200";
        }
        moneyEl.innerHTML = `
            <div class="${coinClass}">
                <div class="coin-value">${labelValue}</div>
                <div class="coin-unit">${labelUnit === "EURO" ? "€" : "ct"}</div>
            </div>
        `;
    }

    if (atmMode === "deposit") {
        // Przy wpłacaniu pojawia się na dolnej tacce
        dispenser.appendChild(moneyEl);
    } else {
        // Przy wypłacaniu wsadzamy go bezpośrednio do szczeliny
        // Dodajemy specjalną klasę '.in-slot-half' i animację wysuwania z wnętrza szczeliny
        moneyEl.classList.add("in-slot-half", "slid-out-money");
        targetSlot.appendChild(moneyEl);
    }

    if(isAiBotRunning) {
        setTimeout(() => {
            if(atmMode === "deposit") {
                moneyEl.classList.add("auto-flying");
            } else {
                moneyEl.classList.add("auto-flying-from");
            }
            setTimeout(() => {
                remainingAmount = Math.max(0, Math.round((remainingAmount - currentItem.value) * 100) / 100);
                currentDenominationIndex++;
                processNextDenomination();
            }, 250);
        }, 450);
        return;
    }

    initDragAndDrop(moneyEl, currentItem.value);
}

function triggerAiBotFastExecution() {
    isAiBotRunning = true;
    document.getElementById("aiBotBtn").style.opacity = "0.4";
    document.getElementById("aiBotBtn").disabled = true;
    document.getElementById("atmAbortBtn").style.display = "none";
    document.getElementById("atmTopCloseBtn").style.display = "none";
    processNextDenomination();
}

function initDragAndDrop(el, value) {
    let isDragging = false;
    let startX = 0, startY = 0;
    let currentX = 0, currentY = 0;
    
    // Jeśli wypłacamy, bazowym przesunięciem jest -22px (schowanie do połowy w szczelinie)
    let initialYOffset = (atmMode === "withdraw") ? -22 : 0;
    currentY = initialYOffset;

    const targetSlot = document.getElementById("atmSlotTarget");
    const dispenser = document.getElementById("moneyDispenser");

    const startEvent = (e) => {
        if(isAiBotRunning) return;
        isDragging = true;
        
        // Wyłączamy animację wysuwania, gdy użytkownik dotknie pieniądza
        el.classList.remove("slid-out-money");

        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        
        startX = clientX - currentX;
        startY = clientY - currentY;
        el.style.transition = "none";
    };

    const moveEvent = (e) => {
        if (!isDragging || isAiBotRunning) return;
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        
        currentX = clientX - startX;
        currentY = clientY - startY;

        el.style.transform = `translate(${currentX}px, ${currentY}px)`;

        const slotRect = targetSlot.getBoundingClientRect();
        const dispenserRect = dispenser.getBoundingClientRect();
        const moneyRect = el.getBoundingClientRect();

        const moneyCenterX = moneyRect.left + (moneyRect.width / 2);
        const moneyCenterY = moneyRect.top + (moneyRect.height / 2);

        if (atmMode === "deposit") {
            const slotCenterX = slotRect.left + (slotRect.width / 2);
            const slotCenterY = slotRect.top + (slotRect.height / 2);
            const distanceX = Math.abs(moneyCenterX - slotCenterX);
            const distanceY = Math.abs(moneyCenterY - slotCenterY);

            // Wrzucanie do szczeliny
            if (distanceY < 45 && distanceX < 110) {
                isDragging = false;
                cleanListeners();
                
                targetSlot.style.borderColor = "#10b981";
                targetSlot.style.boxShadow = "0 0 25px rgba(16,185,129,0.9)";
                
                el.style.transition = "all 0.2s ease-in-out";
                el.style.transform = `translate(${currentX}px, ${currentY - 50}px) scale(0.05)`;
                el.style.opacity = "0";

                setTimeout(() => {
                    targetSlot.style.borderColor = "#06b6d4";
                    targetSlot.style.boxShadow = "0 0 15px rgba(6,182,212,0.4)";
                    
                    remainingAmount = Math.max(0, Math.round((remainingAmount - value) * 100) / 100);
                    currentDenominationIndex++;
                    processNextDenomination();
                }, 200);
            }
        } else {
            // Wyciąganie ze szczeliny (w dół na tackę)
            if (moneyCenterX > dispenserRect.left && moneyCenterX < dispenserRect.right &&
                moneyCenterY > dispenserRect.top && moneyCenterY < dispenserRect.bottom) {
                
                isDragging = false;
                cleanListeners();
                
                dispenser.style.borderColor = "#10b981";
                dispenser.style.background = "rgba(16,185,129,0.1)";
                
                el.style.transition = "all 0.2s ease-in-out";
                el.style.transform = `translate(${currentX}px, ${currentY + 30}px) scale(0.2)`;
                el.style.opacity = "0";

                setTimeout(() => {
                    dispenser.style.borderColor = "rgba(255,255,255,0.1)";
                    dispenser.style.background = "rgba(0,0,0,0.2)";
                    
                    remainingAmount = Math.max(0, Math.round((remainingAmount - value) * 100) / 100);
                    currentDenominationIndex++;
                    processNextDenomination();
                }, 200);
            }
        }
    };

    const endEvent = () => {
        if (!isDragging) return;
        isDragging = false;

        el.style.transition = "transform 0.3s cubic-bezier(0.25, 1, 0.5, 1)";
        // Powrót na bezpieczną pozycję (0 przy wpłacie, -22px w szczelinie przy wypłacie)
        currentX = 0;
        currentY = initialYOffset;
        el.style.transform = `translate(${currentX}px, ${currentY}px)`;
    };

    function cleanListeners() {
        document.removeEventListener("mousemove", moveEvent);
        document.removeEventListener("mouseup", endEvent);
        document.removeEventListener("touchmove", moveEvent);
        document.removeEventListener("touchend", endEvent);
    }

    el.addEventListener("mousedown", startEvent);
    document.addEventListener("mousemove", moveEvent);
    document.addEventListener("mouseup", endEvent);

    el.addEventListener("touchstart", startEvent, { passive: true });
    document.addEventListener("touchmove", moveEvent, { passive: false });
    document.addEventListener("touchend", endEvent);
}

function executeFinalTransaction() {
    const t = translations[data.lang];
    const now = new Date();
    const dateStr = now.toLocaleDateString() + " " + now.toLocaleTimeString();

    if (atmMode === "deposit") {
        data.balance += totalTargetAmount;
        data.history.unshift({
            id: Date.now() + Math.random(),
            type: "deposit",
            text: t.histDeposit,
            amount: totalTargetAmount,
            date: dateStr
        });
        processNotification(`${t.ntfDeposit}${totalTargetAmount.toFixed(2)} €`);
    } else {
        data.balance -= totalTargetAmount;
        data.history.unshift({
            id: Date.now() + Math.random(),
            type: "withdraw",
            text: pendingReason ? `${t.histWithdrawReason}${pendingReason}` : t.histWithdrawDefault,
            amount: totalTargetAmount,
            date: dateStr
        });
        const details = pendingReason ? `${t.ntfWithdrawFor}"${pendingReason}"` : "";
        processNotification(`${t.ntfWithdraw}${totalTargetAmount.toFixed(2)} €${details}`);
    }

    document.getElementById("atmAmount").value = "";
    document.getElementById("atmReason").value = "";
    
    closeATM();
    updateUI();
}

function deleteOneTransaction(id) {
    const itemIndex = data.history.findIndex(item => item.id === id);
    if(itemIndex === -1) return;
    const item = data.history[itemIndex];
    if(item.type === "deposit") {
        data.balance = Math.max(0, data.balance - item.amount);
    } else if(item.type === "withdraw" || item.type === "goal" || item.type === "buy") {
        data.balance += item.amount;
    }
    data.history.splice(itemIndex, 1);
    updateUI();
}

function clearAllTransactions() {
    data.history = [];
    updateUI();
}

function clearAllNotifications() {
    data.notificationsLog = [];
    updateUI();
}

function processNotification(message) {
    if(data.notificationChoice === "denied") return;
    const now = new Date();
    const timeStr = now.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});

    if(!data.notificationsLog) data.notificationsLog = [];
    const newNtf = { id: Date.now() + Math.random(), text: message, time: timeStr };
    data.notificationsLog.unshift(newNtf);

    const container = document.getElementById("toastContainer");
    if(container) {
        const toast = document.createElement("div");
        toast.className = "in-app-toast";
        const headerName = translations[data.lang].bannerHeaderName;
        toast.innerHTML = `
            <div style="font-size: 20px;">🔔</div>
            <div style="flex: 1; font-size: 12px; font-weight: 700; color: #1e293b;">
                <div style="font-size: 9px; color: #06b6d4; text-transform: uppercase;">${headerName}</div>
                <div>${message}</div>
            </div>
        `;
        toast.onclick = () => toast.remove();
        container.appendChild(toast);
        setTimeout(() => toast.classList.add("show"), 50);
        setTimeout(() => { if(toast.parentNode) toast.remove(); }, 4000);
    }
    renderAppNotifications();
    save();
}

function triggerNotificationTest() {
    const t = translations[data.lang];
    processNotification(t.testSuccessMsg);
    document.getElementById("testNtfModal").style.display = "flex";
}

function closeTestNtfModal() { document.getElementById("testNtfModal").style.display = "none"; }

function switchTab(tab) {
    activeTab = tab;
    const transBtn = document.getElementById("tabTransBtn");
    const notifBtn = document.getElementById("tabNotifBtn");
    const transView = document.getElementById("tabTransactionsView");
    const notifView = document.getElementById("tabNotificationsView");

    if(tab === "trans") {
        transBtn.classList.add("active");
        notifBtn.classList.remove("active");
        transView.style.display = "block";
        notifView.style.display = "none";
    } else {
        transBtn.classList.remove("active");
        notifBtn.classList.add("active");
        transView.style.display = "none";
        notifView.style.display = "block";
    }
}

function toggleNotificationsManually() {
    data.notificationChoice = (data.notificationChoice === "granted") ? "denied" : "granted";
    save();
    updateStatusBadge();
}

function updateStatusBadge() {
    const badge = document.getElementById("ntfStatusBadge");
    const textEl = document.getElementById("ntfStatusText");
    const pluskaEl = document.getElementById("ntfStatusPluska");
    const t = translations[data.lang];
    
    if (data.notificationChoice === "granted") {
        textEl.innerText = t.statusActive; pluskaEl.innerText = "🟢";
        badge.style.background = "#dcfce7"; badge.style.borderColor = "#86efac"; badge.style.color = "#166534";
    } else {
        textEl.innerText = t.statusDisabled; pluskaEl.innerText = "🔴";
        badge.style.background = "#fee2e2"; badge.style.borderColor = "#fca5a5"; badge.style.color = "#991b1b";
    }
}

function save(){ localStorage.setItem("bubbleGardenFullInterReal",JSON.stringify(data)); }

function load(){
    const stored=localStorage.getItem("bubbleGardenFullInterReal");
    if(stored){
        data=JSON.parse(stored);
        if(!data.notificationsLog) data.notificationsLog = [];
    }
}

function resetApp(){ localStorage.removeItem("bubbleGardenFullInterReal"); location.reload(); }

function setLanguageFirstTime(langCode) {
    data.lang = langCode;
    data.hasChosenLangBefore = true; 
    document.getElementById("firstTimeLangModal").style.display = "none";
    updateUI();
}

function checkFirstTimeLanguagePrompt() {
    if (!data.hasChosenLangBefore) {
        document.getElementById("firstTimeLangModal").style.display = "flex";
    } else {
        document.getElementById("firstTimeLangModal").style.display = "none";
    }
}

function updateUI(){
    const t = translations[data.lang];
    
    document.getElementById("appTitle").innerText = t.appTitle;
    document.getElementById("appSubtitle").innerText = t.appSubtitle;
    document.getElementById("freeFundsLabel").innerText = t.freeFunds;
    document.getElementById("depositBtn").innerText = t.deposit;
    document.getElementById("withdrawBtn").innerText = t.withdraw;
    document.getElementById("gardenWaterLabel").innerText = t.gardenWater;
    document.getElementById("waterPlantsLabel").innerText = t.waterPlants;
    document.getElementById("savingsGoalsLabel").innerText = t.savingsGoals;
    document.getElementById("newGoalBtn").innerText = t.newGoal;
    document.getElementById("yourGardenLabel").innerText = t.yourGarden;
    document.getElementById("textTabTrans").innerText = t.tabTrans;
    document.getElementById("textTabNotif").innerText = t.tabNotif;
    document.getElementById("savedAlertsLabel").innerText = t.savedAlerts;
    document.getElementById("savedTransLabel").innerText = t.savedTrans;
    document.getElementById("clearAllNtfBtn").innerText = t.clearAllBtn;
    document.getElementById("clearAllTransBtn").innerText = t.clearAllBtn;
    document.getElementById("testNtfBtn").innerText = t.testBtn;
    
    document.getElementById("testModalTitle").innerText = t.testModalTitle;
    document.getElementById("testModalDesc").innerText = t.testModalDesc;
    document.getElementById("testModalCloseBtn").innerText = t.confirm;

    document.getElementById("atmTitle").innerText = t.atmTitleText;
    document.getElementById("atmCancelBtn").innerText = t.cancel;
    document.getElementById("atmConfirmBtn").innerText = t.confirm;
    document.getElementById("atmAmount").placeholder = t.atmAmountPlh;
    document.getElementById("atmReason").placeholder = t.atmReasonPlh;
    document.getElementById("aiBotBtn").innerText = t.aiBotBtnText;
    document.getElementById("atmAbortBtn").innerText = t.atmAbortBtnText;

    document.getElementById("newGoalTitle").innerText = t.newGoalTitle;
    document.getElementById("goalName").placeholder = t.goalNamePlh;
    document.getElementById("goalTarget").placeholder = t.goalTargetPlh;
    document.getElementById("createGoalBtn").innerText = t.createGoalBtn;
    document.getElementById("historyTitle").innerText = t.historyTitle;
    document.getElementById("langModalTitle").innerText = t.langModalTitle;
    document.getElementById("langCloseBtn").innerText = t.langCloseBtn;
    
    document.getElementById("balanceText").innerText=data.balance.toFixed(2);
    document.getElementById("waterText").innerText=data.water;

    updateStatusBadge();
    renderLangSelect();
    renderGoals();
    renderGarden();
    renderHistory();
    renderAppNotifications();
    save();
}

function openATM(type){
    atmMode=type;
    resetAtmStage();
    document.getElementById("atmModal").style.display="flex";
}
function closeATM(){ document.getElementById("atmModal").style.display="none"; }
function openLangModal(){ document.getElementById("langModal").style.display="flex"; }
function closeLangModal(){ document.getElementById("langModal").style.display="none"; }
function changeLanguage(langCode){ data.lang = langCode; updateUI(); }

function renderLangSelect(){
    const select = document.getElementById("langSelect");
    const t = translations[data.lang];
    select.innerHTML = `
        <option value="pl" ${data.lang==='pl'?'selected':''}>${t.langNames.pl}</option>
        <option value="en" ${data.lang==='en'?'selected':''}>${t.langNames.en}</option>
        <option value="de" ${data.lang==='de'?'selected':''}>${t.langNames.de}</option>
    `;
}

function openGoalModal(){ document.getElementById("goalModal").style.display="flex"; }
function closeGoalModal(){ document.getElementById("goalModal").style.display="none"; }

function createGoal(){
    const t = translations[data.lang];
    const name=document.getElementById("goalName").value;
    const target=parseFloat(document.getElementById("goalTarget").value);
    if(!name||isNaN(target)||target<=0)return;
    data.goals.push({id:Date.now(),name:name,target:target,current:0});
    processNotification(`${t.ntfNewGoal}"${name}" (${target.toFixed(0)} €)`);
    document.getElementById("goalName").value="";
    document.getElementById("goalTarget").value="";
    closeGoalModal();
    updateUI();
}

function addToGoal(id){
    const t = translations[data.lang];
    const val=prompt(t.promptAddGoal);
    const amount=parseFloat(val);
    if(isNaN(amount)||amount<=0)return;
    if(amount>data.balance){ alert(t.alertNoFunds); return; }

    const goal=data.goals.find(g=>g.id===id);
    goal.current+=amount;
    data.balance-=amount;
    data.water+=Math.max(1,Math.floor(amount/5));

    data.history.unshift({
        id: Date.now() + Math.random(),
        type:"goal",
        text: `${t.histGoal}${goal.name}`,
        amount:amount,
        date:new Date().toLocaleString()
    });
    processNotification(`${t.ntfGoalAdded}"${goal.name}": +${amount.toFixed(2)} €`);
    updateUI();
}

function buyGoal(id){
    const t = translations[data.lang];
    const goal=data.goals.find(g=>g.id===id);
    if(goal.current<goal.target){ alert(t.alertLowSavings); return; }
    goal.current-=goal.target;
    data.history.unshift({
        id: Date.now() + Math.random(),
        type:"buy",
        text: `${t.histBuy}${goal.name}`,
        amount:goal.target,
        date:new Date().toLocaleString()
    });
    processNotification(`${t.ntfGoalSuccess}"${goal.name}" 🛍️`);
    updateUI();
}

function removeGoal(id){ data.goals=data.goals.filter(g=>g.id!==id); updateUI(); }

function renderGoals(){
    const t = translations[data.lang];
    const wrap=document.getElementById("goalsWrap");
    wrap.innerHTML="";
    if(data.goals.length===0){
        wrap.innerHTML=`<div style="background:white;border-radius:24px;padding:30px;text-align:center;color:#94a3b8;border:1px dashed #cbd5e1; font-size:12px;">${t.noGoals}</div>`;
        return;
    }
    data.goals.forEach(goal=>{
        const percent=Math.min(Math.round((goal.current/goal.target)*100),100);
        let bubblesHTML="";
        for(let i=0;i<6;i++){
            bubblesHTML+=`<div class="bubble" style="width:10px; height:10px; left:${Math.random()*100}%; bottom:-20px; background:#38bdf8; animation-duration:${3+Math.random()*2}s;"></div>`;
        }
        wrap.innerHTML+=`
            <div class="goalCard">
                <div style="font-weight:900;font-size:15px;text-align:center;">${goal.name}</div>
                <div style="font-size:11px;color:#64748b;text-align:center;margin-top:4px;">${goal.current.toFixed(0)} € / ${goal.target.toFixed(0)} €</div>
                <div style="width:100px; height:100px; margin:10px auto; border-radius:999px; background:#f8fafc; padding:4px; position:relative; overflow:hidden; border:4px solid #67e8f9;">
                    <div style="width:100%; height:100%; border-radius:999px; overflow:hidden; position:relative;">
                        <div class="wave" style="top:${100-percent}%; background:#34d399;"></div>
                        ${bubblesHTML}
                        <div style="position:absolute; inset:0; display:flex; justify-content:center; align-items:center; font-size:22px; font-weight:900; color:#1e293b; z-index:5;">${percent}%</div>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;">
                    <button onclick="addToGoal(${goal.id})" class="mainBtn" style="background:#cffafe;color:#0891b2;font-size:11px; padding:8px;">${t.goalBtnAdd}</button>
                    <button onclick="buyGoal(${goal.id})" class="mainBtn" style="background:#10b981;color:white;font-size:11px; padding:8px;">${t.goalBtnBuy}</button>
                    <button onclick="removeGoal(${goal.id})" class="mainBtn" style="background:#fee2e2;color:#ef4444;font-size:11px; padding:8px;">✕</button>
                </div>
            </div>
        `;
    });
}

function renderGarden(){
    const t = translations[data.lang];
    const wrap=document.getElementById("gardenWrap");
    wrap.innerHTML="";
    data.garden.forEach((slot,index)=>{
        if(!slot.planted){
            wrap.innerHTML+=`<div class="slot" onclick="plantSeed(${index})"><div style="font-size:36px;">🟤</div><div style="margin-top:6px;font-weight:900;font-size:11px;">${t.emptySoil}</div></div>`;
        }else{
            wrap.innerHTML+=`
                <div class="slot" onclick="waterPlant(${index})">
                    <div style="font-size:36px;">${slot.emoji}</div>
                    <div style="margin-top:4px;font-weight:900;font-size:11px;">${slot.translatedName || slot.name}</div>
                    <div style="width:100%;height:6px;background:#e2e8f0;border-radius:999px;margin-top:6px;overflow:hidden;">
                        <div style="width:${slot.progress}%; height:100%; background:#10b981;"></div>
                    </div>
                </div>
            `;
        }
    });
}

function plantSeed(index){
    const t = translations[data.lang];
    if(data.inventory.length===0) { alert(t.alertNoSeeds); return; }
    const emoji=data.inventory.shift();
    let name="Roślina", transName = t.plantPlant;
    if(emoji==="🥕") { name="Marchewka"; transName = t.plantCarrot; }
    if(emoji==="🍅") { name="Pomidor"; transName = t.plantTomato; }
    if(emoji==="🧅") { name="Cebula"; transName = t.plantOnion; }
    if(emoji==="🍎") { name="Jabłoń"; transName = t.plantApple; }

    data.garden[index]={planted:true,emoji:emoji,name:name,translatedName:transName,progress:0};
    updateUI();
}

function waterPlant(index){
    const t = translations[data.lang];
    const slot=data.garden[index];
    if(!slot.planted || data.water<=0) return;
    data.water-=1; slot.progress+=20;
    if(slot.progress>100) slot.progress=100;
    if(slot.progress>=100){
        data.inventory.push("🥕");
        processNotification(t.ntfHarvest);
        setTimeout(()=>{ data.garden[index]={planted:false}; updateUI(); },400);
    }
    updateUI();
}

function openHistory(){ document.getElementById("historyModal").style.display="flex"; switchTab(activeTab); }
function closeHistory(){ document.getElementById("historyModal").style.display="none"; }

function renderHistory(){
    const t = translations[data.lang];
    const wrap=document.getElementById("historyWrap");
    wrap.innerHTML="";
    if(data.history.length===0){
        wrap.innerHTML=`<div style="text-align:center;color:#94a3b8;padding:15px;font-size:11px;">${t.noHistory}</div>`; return;
    }
    data.history.forEach(item=>{
        wrap.innerHTML+=`
            <div class="histItem">
                <div style="flex:1; min-width: 0; padding-right: 8px;">
                    <div style="font-weight:900;font-size:12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${item.text}</div>
                    <div style="font-size:9px;color:#64748b;">${item.date}</div>
                </div>
                <div style="display:flex; align-items:center; gap:8px; flex-shrink: 0;">
                    <div style="font-weight:900; font-size:13px; color:${item.type==="deposit"?"#10b981":"#ef4444"};">${item.type==="deposit"?"+":"-"}${item.amount.toFixed(2)} €</div>
                    <button onclick="deleteOneTransaction(${item.id})" style="color:#cbd5e1; font-weight:900; font-size:14px; cursor:pointer; padding:2px 6px;">✕</button>
                </div>
            </div>
        `;
    });
}

function renderAppNotifications() {
    const t = translations[data.lang];
    const wrap = document.getElementById("appNotificationsWrap");
    if(!wrap) return;
    wrap.innerHTML = "";
    if(!data.notificationsLog || data.notificationsLog.length === 0) {
        wrap.innerHTML = `<div style="text-align:center; color:#94a3b8; font-size:11px; padding:15px;">${t.noNotifications}</div>`; return;
    }
    data.notificationsLog.forEach(ntf => {
        wrap.innerHTML += `
            <div style="background:#f8fafc; border-radius:12px; padding:8px 12px; display:flex; justify-content:space-between; align-items:center; border:1px solid #e2e8f0; font-size:11px; font-weight:700;">
                <div style="flex:1; color:#334155; padding-right:6px;">${ntf.text}</div>
                <div style="display:flex; align-items:center; gap:6px; flex-shrink: 0;">
                    <span style="font-size:9px; color:#94a3b8;">${ntf.time}</span>
                </div>
            </div>
        `;
    });
}

load();
updateUI();
checkFirstTimeLanguagePrompt(); 
</script>
</body>
</html>
