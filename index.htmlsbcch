<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Bąbelkowy Ogród Finansowy PRO + Realistyczny Bankomat</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>
html, body {
height: 100%;
margin: 0;
overflow: hidden;
font-family: sans-serif;
touch-action: none;
/* Blokuje odciąganie strony na iOS/Android (efekt gumy) */
overscroll-behavior: none; 
}

body {
background: linear-gradient(135deg, #e0f2fe 0%, #f8fafc 50%, #f0fdf4 100%);
background-size: 200% 200%;
animation: bgMove 12s ease infinite;
display: flex;
justify-content: center;
align-items: center;
padding: 10px;
position: relative;
user-select: none;
-webkit-user-select: none;
}

@keyframes bgMove {
0% { background-position: 0% 50%; }
50% { background-position: 100% 50%; }
100% { background-position: 0% 50%; }
}

.app {
width: 100%;
max-width: 430px;
height: 100%; 
max-height: 92vh; 
background: rgba(255, 255, 255, .88);
backdrop-filter: blur(20px);
-webkit-backdrop-filter: blur(20px);
border-radius: 38px;
overflow: hidden;
display: flex;
flex-direction: column;
box-shadow: 0 25px 60px rgba(0, 0, 0, .12);
border: 1px solid rgba(255, 255, 255, .7);
position: relative;
}

.scroll {
flex: 1;
overflow-y: auto;
padding: 16px;
-webkit-overflow-scrolling: touch;
}

/* Ukrywanie paska przewijania */
.scroll::-webkit-scrollbar {
display: none;
}

.topbar {
background: linear-gradient(90deg, #22d3ee, #10b981);
padding: 14px 16px;
display: flex;
justify-content: space-between;
align-items: center;
color: white;
z-index: 10;
flex-shrink: 0;
}

.title {
font-weight: 900;
font-size: 14px;
}

.notification-container {
position: absolute;
top: 75px;
left: 16px;
right: 16px;
z-index: 9999;
display: flex;
flex-direction: column;
gap: 10px;
pointer-events: none;
}

.in-app-toast {
background: white;
border-radius: 20px;
padding: 14px 18px;
box-shadow: 0 15px 35px rgba(15, 23, 42, 0.15);
border: 1px solid #e2e8f0;
display: flex;
gap: 12px;
align-items: center;
transform: translateY(-40px);
opacity: 0;
transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
pointer-events: auto;
cursor: pointer;
}

.in-app-toast.show {
transform: translateY(0);
opacity: 1;
}

.balanceCard {
background: white;
border-radius: 28px;
padding: 20px;
border: 2px solid #cffafe;
box-shadow: 0 0 25px rgba(34, 211, 238, .18);
}

.goalCard {
background: white;
border-radius: 28px;
padding: 18px;
position: relative;
overflow: hidden;
border: 1px solid #e2e8f0;
}

.wave {
position: absolute;
width: 220%;
height: 220%;
left: -60%;
border-radius: 40%;
animation: waveRotate 10s linear infinite;
}

@keyframes waveRotate {
0% { transform: rotate(0deg); }
100% { transform: rotate(360deg); }
}

.bubble {
position: absolute;
border-radius: 999px;
animation: bubbleUp linear infinite;
opacity: .8;
}

@keyframes bubbleUp {
0% { transform: translateY(0) scale(.5); opacity: 0; }
20% { opacity: 1; }
100% { transform: translateY(-170px) scale(1.5); opacity: 0; }
}

.slot {
background: white;
border-radius: 24px;
padding: 14px;
height: 140px; 
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
border: 1px solid #e2e8f0;
transition: .2s;
}

.slot:active { transform: scale(.97); }

.modal {
position: absolute;
inset: 0;
background: rgba(0, 0, 0, .4);
backdrop-filter: blur(5px);
-webkit-backdrop-filter: blur(5px);
display: none;
justify-content: center;
align-items: center;
padding: 16px;
z-index: 100;
}

.modalBox {
background: white;
width: 100%;
border-radius: 28px;
padding: 20px;
max-height: 85vh; 
overflow-y: auto;
box-sizing: border-box;
}

.modalBox::-webkit-scrollbar {
display: none;
}

input, select {
width: 100%;
padding: 12px 14px;
border-radius: 16px;
border: 1px solid #cbd5e1;
background: #f8fafc;
font-weight: 700;
outline: none;
font-size: 14px;
}

.mainBtn {
padding: 12px 14px;
border-radius: 18px;
font-weight: 900;
border: none;
cursor: pointer;
font-size: 13px;
transition: background 0.2s, transform 0.1s;
}
.mainBtn:active {
transform: scale(0.97);
}

.histItem {
background: white;
border-radius: 18px;
padding: 12px;
display: flex;
justify-content: space-between;
align-items: center;
border: 1px solid #e2e8f0;
}

.tab-btn {
flex: 1;
padding: 10px;
font-weight: 800;
font-size: 11px;
border-radius: 12px;
background: #f1f5f9;
color: #64748b;
border: none;
cursor: pointer;
text-transform: uppercase;
display: flex;
align-items: center;
justify-content: center;
gap: 4px;
}

.tab-btn.active {
background: #06b6d4;
color: white;
}

/* STYLE BANKOMATU */
.atm-machine {
background: linear-gradient(180deg, #0f172a, #1e293b, #334155);
border-radius: 24px;
padding: 16px; 
color: white;
text-align: center;
position: relative;
border: 4px solid #475569;
box-shadow: inset 0 0 30px rgba(0,0,0,0.8), 0 15px 30px rgba(0,0,0,0.3);
}

.atm-screen {
background: #020617;
border: 2px solid #334155;
border-radius: 12px;
padding: 8px;
font-family: monospace;
color: #38bdf8;
font-size: 11px;
margin-bottom: 12px;
box-shadow: inset 0 0 10px rgba(56,189,248,0.2);
}

/* 
  NOWA STRUKTURA SZCZELINY:
  Dzięki overflow: hidden; i względnemu pozycjonowaniu, 
  wszystko co jest w środku wygląda jakby tkwiło głęboko w maszynie.
*/
.atm-slot {
background: #020617;
height: 44px;
border-radius: 8px;
margin: 12px auto; 
width: 85%;
border: 2px solid #06b6d4;
box-shadow: 0 0 15px rgba(6,182,212,0.4);
position: relative;
overflow: hidden; /* Odcina wystające elementy tworząc efekt "schowania" */
transition: all 0.2s;
display: flex;
justify-content: center;
align-items: center;
}

.atm-slot.pulse {
animation: slotGlow 1.2s ease-in-out infinite alternate;
}

@keyframes slotGlow {
0% { border-color: #06b6d4; box-shadow: 0 0 5px rgba(6,182,212,0.4); }
100% { border-color: #10b981; box-shadow: 0 0 25px rgba(16,185,129,0.7); }
}

.money-dispenser {
height: 120px; 
position: relative;
background: rgba(0,0,0,0.2);
border-radius: 20px;
border: 2px dashed rgba(255,255,255,0.1);
display: flex;
justify-content: center;
align-items: center;
overflow: visible;
margin-top: 10px;
}

.draggable-money {
cursor: grab;
position: relative;
z-index: 50;
user-select: none;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
touch-action: none;
will-change: transform;
}
.draggable-money:active { cursor: grabbing; }

/* 
  Efekt wsadzenia do połowy przy wypłacie realizujemy poprzez domyślny styl, 
  który wsuwa element do szczeliny za pomocą transformacji na start.
*/
.draggable-money.in-slot-half {
  transform: translateY(-22px); /* Wsuwa banknot/monetę do połowy w głąb szczeliny */
}

.real-bill {
width: 120px; 
height: 60px;  
border-radius: 6px;
position: relative;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
border: 2px double rgba(255,255,255,0.6);
box-shadow: 0 6px 12px rgba(0,0,0,0.4), inset 0 0 10px rgba(0,0,0,0.15);
color: white;
font-family: 'Georgia', serif;
font-weight: bold;
text-shadow: 1px 1px 3px rgba(0,0,0,0.5);
}

.real-bill::before {
content: "";
position: absolute;
inset: 3px;
border: 1px solid rgba(255,255,255,0.3);
border-radius: 2px;
pointer-events: none;
}

.bill-center-value {
font-size: 18px; 
letter-spacing: 1px;
z-index: 2;
}

.bill-bottom-text {
font-size: 8px;
font-family: sans-serif;
opacity: 0.9;
margin-top: 1px;
background: rgba(0,0,0,0.2);
padding: 1px 4px;
border-radius: 4px;
text-transform: uppercase;
letter-spacing: 0.5px;
z-index: 2;
}

.real-coin {
width: 55px; 
height: 55px; 
border-radius: 999px;
background: linear-gradient(135deg, #fcd34d, #f59e0b, #d97706);
border: 2px solid #b45309;
box-shadow: 0 4px 8px rgba(0,0,0,0.4), inset -2px -2px 4px rgba(0,0,0,0.4), inset 2px 2px 4px rgba(255,255,255,0.4);
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
color: #78350f;
font-weight: 900;
position: relative;
}

.real-coin.silver {
background: linear-gradient(135deg, #e2e8f0, #cbd5e1, #94a3b8);
border: 2px solid #64748b;
color: #334155;
}

.coin-value {
font-size: 15px;
line-height: 1;
}

.coin-unit {
font-size: 8px;
text-transform: uppercase;
font-weight: 800;
}

/* Animacja wysuwania się pieniędzy z bankomatu */
@keyframes slideOutFromSlot {
0% { transform: translateY(-70px); opacity: 0; }
100% { transform: translateY(-22px); opacity: 1; } /* Zatrzymuje się idealnie w połowie szczeliny */
}

/* Animacja wkładania gotówki przy wpłacie */
@keyframes printMoney {
0% { transform: translateY(30px) scale(0.2); opacity: 0; }
100% { transform: translateY(0) scale(1); opacity: 1; }
}

@keyframes autoFlyToSlot {
0% { transform: translate(0, 0) scale(1); opacity: 1; }
100% { transform: translate(0, -90px) scale(0.1); opacity: 0; }
}

@keyframes autoFlyFromSlot {
0% { transform: translateY(-22px) scale(1); opacity: 1; }
100% { transform: translateY(80px) scale(1); opacity: 0; }
}

.printed-money {
animation: printMoney 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

.slid-out-money {
animation: slideOutFromSlot 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.auto-flying {
animation: autoFlyToSlot 0.3s ease-in forwards !important;
}

.auto-flying-from {
animation: autoFlyFromSlot 0.3s ease-in forwards !important;
}
</style>
</head>

<body>

<div class="modal" id="firstTimeLangModal" style="z-index: 999999; display: none;">
<div class="modalBox" style="text-align: center; max-width: 360px;">
<div style="font-size: 40px; margin-bottom: 10px;">🌐</div>
<div style="font-size: 18px; font-weight: 900; color: #0f172a;">Welcome / Willkommen / Witaj</div>
<div style="font-size: 13px; color: #64748b; margin-top: 8px; margin-bottom: 20px; font-weight: 600; line-height: 1.5;">
Choose language / Wähle deine Sprache / Wybierz język:
</div>
<div style="display: flex; flex-direction: column; gap: 10px;">
<button onclick="setLanguageFirstTime('pl')" class="mainBtn" style="background: #06b6d4; color: white; width: 100%;">Polski</button>
<button onclick="setLanguageFirstTime('en')" class="mainBtn" style="background: #0f172a; color: white; width: 100%;">English</button>
<button onclick="setLanguageFirstTime('de')" class="mainBtn" style="background: #10b981; color: white; width: 100%;">Deutsch</button>
</div>
</div>
</div>

<div class="app">

<div class="notification-container" id="toastContainer"></div>

<div class="topbar">
<div>
<div class="title" id="appTitle">🫧 BĄBELKOWY OGRÓD</div>
<div style="font-size:10px;opacity:.9;" id="appSubtitle">Premium Financial Garden</div>
</div>
<div style="display:flex;gap:8px;align-items:center;">
<button onclick="openLangModal()" style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;cursor:pointer;">🌐</button>
<button onclick="openHistory()" style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;cursor:pointer;">📊</button>
<button onclick="resetApp()" style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;cursor:pointer;">♻️</button>
</div>
</div>

<div class="scroll">

<div class="balanceCard">
<div id="freeFundsLabel" style="font-size:10px;font-weight:900;color:#94a3b8;text-transform:uppercase;">Wolne środki</div>
<div style="font-size:42px;font-weight:900;margin-top:6px;"><span id="balanceText">0.00</span> €</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:18px;">
<button onclick="openATM('deposit')" class="mainBtn" id="depositBtn" style="background:#06b6d4; color:white;">💵 WPŁAĆ</button>
<button onclick="openATM('withdraw')" class="mainBtn" id="withdrawBtn" style="background:#10b981; color:white;">💸 WYDAJ</button>
</div>
</div>

<div style="background:linear-gradient(90deg,#dbeafe,#cffafe);padding:18px;border-radius:24px;border:1px solid #bfdbfe;display:flex;justify-content:space-between;align-items:center;margin-top:16px;">
<div>
<div id="gardenWaterLabel" style="font-size:11px;font-weight:900;color:#0369a1;">💧 Woda ogrodowa</div>
<div id="waterPlantsLabel" style="font-size:10px;color:#64748b;margin-top:2px;">Podlewaj rośliny</div>
</div>
<div style="font-size:32px;font-weight:900;color:#0284c7;"><span id="waterText">0</span></div>
</div>

<div style="margin-top:22px;display:flex;justify-content:space-between;align-items:center;">
<div id="savingsGoalsLabel" style="font-size:12px;font-weight:900;color:#475569;text-transform:uppercase;">Cele oszczędnościowe</div>
<button onclick="openGoalModal()" id="newGoalBtn" style="font-size:11px; font-weight:900; color:#06b6d4; background:none; border:none; cursor:pointer;">+ NOWY</button>
</div>
<div id="goalsWrap" style="margin-top:14px;display:flex;flex-direction:column;gap:16px;"></div>

<div id="yourGardenLabel" style="margin-top:28px;font-size:12px;font-weight:900;color:#475569;text-transform:uppercase;">🏡 Twój ogród</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px;" id="gardenWrap"></div>

<div style="margin-top: 24px; border-top: 1px dashed #cbd5e1; padding-top: 20px; margin-bottom: 10px;">
<div onclick="toggleNotificationsManually()" id="ntfStatusBadge" style="padding: 12px 16px; border-radius: 18px; font-size: 12px; font-weight: 800; display: flex; align-items: center; justify-content: space-between; cursor: pointer; transition: 0.2s; border: 1px solid #cbd5e1;">
<span id="ntfStatusText">Stan powiadomień...</span>
<span id="ntfStatusPluska" style="font-size: 16px;">⚪</span>
</div>
<button onclick="triggerNotificationTest()" id="testNtfBtn" class="mainBtn" style="background: #0284c7; color: white; padding: 10px; font-size: 11px; width:100%; margin-top:8px;">🧪 TESTUJ POWIADOMIENIA</button>
</div>

</div>

<div class="modal" id="atmModal">
<div class="modalBox" style="background: #0f172a; color: white; border: 2px solid #334155; max-width:380px;">
<div style="display:flex;justify-content:space-between;align-items:center; margin-bottom: 10px;">
<div id="atmTitle" style="font-size:16px;font-weight:900;color:#06b6d4;">🏧 Realistyczny Bankomat</div>
<button onclick="closeATM()" id="atmTopCloseBtn" style="border:none;background:none;font-size:24px;color:white;cursor:pointer;">✕</button>
</div>

<div id="atmSetupStage">
<div style="margin-top:14px;"><input type="number" step="0.01" id="atmAmount" style="background:#1e293b; color:white; border-color:#475569;"></div>
<div style="margin-top:10px;"><input type="text" id="atmReason" style="background:#1e293b; color:white; border-color:#475569;"></div>
<div style="margin-top:18px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">
<button onclick="closeATM()" class="mainBtn" id="atmCancelBtn" style="background:#334155; color:white;">Anuluj</button>
<button onclick="startAtmInteraction()" class="mainBtn" id="atmConfirmBtn" style="background:#06b6d4;color:white;">Zatwierdź</button>
</div>
</div>

<div id="atmInteractiveStage" style="display:none; margin-top:10px;">
<div class="atm-machine">
    <div class="atm-screen">
        <div id="atmScreenStatus">STATUS...</div>
        <div id="atmScreenRemaining" style="color:#34d399; font-weight:bold; margin-top:4px;">Do rozliczenia: 0.00 €</div>
    </div>
    <div id="atmInstructionText" style="font-size:11px; font-weight:800; color:#e2e8f0; margin-bottom:8px;">Wsuń nominał:</div>
    <div class="atm-slot pulse" id="atmSlotTarget"></div>
    <div class="money-dispenser" id="moneyDispenser"></div>
</div>
<div style="text-align:center; margin-top:12px; display:flex; flex-direction:column; gap:8px;">
<button onclick="triggerAiBotFastExecution()" id="aiBotBtn" class="mainBtn" style="background:linear-gradient(90deg, #a855f7, #06b6d4); color:white; font-size:13px; padding:12px;">⚡ AI-BOT</button>
<button onclick="resetAtmStage()" id="atmAbortBtn" class="mainBtn" style="background:#334155; color:white; font-size:11px; padding:8px 16px;">⬅️ Przerwij</button>
</div>
</div>

</div>
</div>

<div class="modal" id="goalModal">
<div class="modalBox" style="max-width:360px;">
<div style="display:flex;justify-content:space-between;align-items:center;">
<div id="newGoalTitle" style="font-size:18px;font-weight:900;">🎯 Nowy cel</div>
<button onclick="closeGoalModal()" style="border:none;background:none;font-size:24px;">✕</button>
</div>
<div style="margin-top:16px;"><input type="text" id="goalName"></div>
<div style="margin-top:14px;"><input type="number" id="goalTarget"></div>
<div style="margin-top:18px;"><button onclick="createGoal()" class="mainBtn" id="createGoalBtn" style="background:#10b981;color:white;width:100%;">Stwórz cel</button></div>
</div>
</div>

<div class="modal" id="historyModal">
<div class="modalBox" style="padding: 16px; max-width:380px;">
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
<div id="historyTitle" style="font-size:16px;font-weight:900;text-transform:uppercase;color:#1e293b;">📊 Centrum Danych</div>
<button onclick="closeHistory()" style="border:none;background:none;font-size:24px;cursor:pointer;">✕</button>
</div>
<div style="display:flex; gap:8px; background:#e2e8f0; padding:4px; border-radius:14px; margin-bottom:16px;">
<button onclick="switchTab('trans')" id="tabTransBtn" class="tab-btn active">📊 <span id="textTabTrans">Transakcje</span></button>
<button onclick="switchTab('notif')" id="tabNotifBtn" class="tab-btn">🔔 <span id="textTabNotif">Powiadomienia</span></button>
</div>
<div id="tabTransactionsView">
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
<span id="savedTransLabel" style="font-size:11px; font-weight:800; color:#64748b;">REJESTR TRANSAKCJI</span>
<button onclick="clearAllTransactions()" id="clearAllTransBtn" style="background:none; border:none; color:#ef4444; font-size:10px; font-weight:900; cursor:pointer;">WYCZYŚĆ WSZYSTKO</button>
</div>
<div id="historyWrap" style="display:flex;flex-direction:column;gap:10px;"></div>
</div>
<div id="tabNotificationsView" style="display:none;">
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
<span id="savedAlertsLabel" style="font-size:11px; font-weight:800; color:#64748b;">ZAPISANE ALERTY</span>
<button onclick="clearAllNotifications()" id="clearAllNtfBtn" style="background:none; border:none; color:#ef4444; font-size:10px; font-weight:900; cursor:pointer;">WYCZYŚĆ WSZYSTKO</button>
</div>
<div id="appNotificationsWrap" style="display:flex;flex-direction:column;gap:10px; max-height:50vh; overflow-y:auto; padding:2px;"></div>
</div>
</div>
</div>

<div class="modal" id="langModal">
<div class="modalBox" style="max-width:360px;">
<div style="display:flex;justify-content:space-between;align-items:center;">
<div id="langModalTitle" style="font-size:18px;font-weight:900;">🌐 Język / Language / Sprache</div>
<button onclick="closeLangModal()" style="border:none;background:none;font-size:24px;">✕</button>
</div>
<div style="margin-top:20px;display:flex;flex-direction:column;gap:12px;"><select id="langSelect" onchange="changeLanguage(this.value)"></select></div>
<div style="margin-top:20px;"><button onclick="closeLangModal()" class="mainBtn" id="langCloseBtn" style="background:#06b6d4;color:white;width:100%;">OK</button></div>
</div>
</div>

<div class="modal" id="testNtfModal">
<div class="modalBox" style="text-align: center; max-width: 340px;">
<div style="font-size: 44px; margin-bottom: 10px;">🚀</div>
<div id="testModalTitle" style="font-size: 16px; font-weight: 900; color: #0f172a; line-height: 1.4;">Wysłaliśmy Ci testowe powiadomienie!</div>
<div id="testModalDesc" style="font-size: 12px; color: #64748b; margin-top: 8px; margin-bottom: 18px; font-weight: 600;">Opis testu...</div>
<button onclick="closeTestNtfModal()" class="mainBtn" id="testModalCloseBtn" style="background: #10b981; color: white; width: 100%; padding: 12px;">OK</button>
</div>
</div>

</div>

<script>
let atmMode="deposit";
let activeTab="trans";
let totalTargetAmount = 0;
let remainingAmount = 0;
let pendingReason = "";
let currentDenominationsList = [];
let currentDenominationIndex = 0;
let isAiBotRunning = false;

const EURO_DENOMINATIONS = [
    { value: 500.00, type: "bill", bg: "linear-gradient(135deg, #e9d5ff, #c084fc, #a855f7)", border: "#7e22ce" },
    { value: 200.00, type: "bill", bg: "linear-gradient(135deg, #fef08a, #facc15, #eab308)", border: "#a16207" },
    { value: 100.00, type: "bill", bg: "linear-gradient(135deg, #bbf7d0, #4ade80, #22c55e)", border: "#15803d" },
