<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bąbelkowy Ogród Finansowy PRO</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

<style>

html,body{
height:100%;
margin:0;
overflow:hidden;
font-family:sans-serif;
touch-action:pan-y;
}

body{
background:linear-gradient(135deg,#e0f2fe 0%,#f8fafc 50%,#f0fdf4 100%);
background-size:200% 200%;
animation:bgMove 12s ease infinite;
display:flex;
justify-content:center;
align-items:center;
padding:10px;
}

@keyframes bgMove{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

.app{
width:100%;
max-width:430px;
height:96vh;
background:rgba(255,255,255,.88);
backdrop-filter:blur(20px);
border-radius:38px;
overflow:hidden;
display:flex;
flex-direction:column;
box-shadow:0 25px 60px rgba(0,0,0,.12);
border:1px solid rgba(255,255,255,.7);
position:relative;
}

.scroll{
flex:1;
overflow-y:auto;
padding:16px;
-webkit-overflow-scrolling:touch;
}

.topbar{
background:linear-gradient(90deg,#22d3ee,#10b981);
padding:16px;
display:flex;
justify-content:space-between;
align-items:center;
color:white;
}

.title{
font-weight:900;
font-size:14px;
}

.balanceCard{
background:white;
border-radius:28px;
padding:20px;
border:2px solid #cffafe;
box-shadow:0 0 25px rgba(34,211,238,.18);
}

.goalCard{
background:white;
border-radius:28px;
padding:18px;
position:relative;
overflow:hidden;
border:1px solid #e2e8f0;
}

.wave{
position:absolute;
width:220%;
height:220%;
left:-60%;
border-radius:40%;
animation:waveRotate 10s linear infinite;
}

@keyframes waveRotate{
0%{transform:rotate(0deg);}
100%{transform:rotate(360deg);}
}

.bubble{
position:absolute;
border-radius:999px;
animation:bubbleUp linear infinite;
opacity:.8;
}

@keyframes bubbleUp{
0%{
transform:translateY(0) scale(.5);
opacity:0;
}
20%{
opacity:1;
}
100%{
transform:translateY(-170px) scale(1.5);
opacity:0;
}
}

.slot{
background:white;
border-radius:24px;
padding:14px;
height:180px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
border:1px solid #e2e8f0;
transition:.2s;
}

.slot:active{
transform:scale(.97);
}

.modal{
position:absolute;
inset:0;
background:rgba(0,0,0,.4);
backdrop-filter:blur(5px);
display:none;
justify-content:center;
align-items:center;
padding:20px;
z-index:100;
}

.modalBox{
background:white;
width:100%;
border-radius:28px;
padding:20px;
max-height:90vh;
overflow-y:auto;
}

input,select{
width:100%;
padding:14px;
border-radius:16px;
border:1px solid #cbd5e1;
background:#f8fafc;
font-weight:700;
outline:none;
}

.mainBtn{
padding:14px;
border-radius:18px;
font-weight:900;
border:none;
cursor:pointer;
}

.histItem{
background:white;
border-radius:18px;
padding:12px;
display:flex;
justify-content:space-between;
align-items:center;
border:1px solid #e2e8f0;
}

</style>
</head>

<body>

<div class="app">

<!-- HEADER -->

<div class="topbar">

<div>
<div class="title" id="appTitle">
🫧 BĄBELKOWY OGRÓD
</div>

<div style="font-size:10px;opacity:.9;" id="appSubtitle">
Premium Financial Garden
</div>
</div>

<div style="display:flex;gap:8px;align-items:center;">

<button onclick="openLangModal()"
style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;cursor:pointer;">
🌐
</button>

<button onclick="openHistory()"
style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;">
📊
</button>

<button onclick="resetApp()"
style="background:rgba(255,255,255,.2);border:none;padding:10px 12px;border-radius:14px;color:white;font-weight:900;">
♻️
</button>

</div>

</div>

<!-- SCROLL -->

<div class="scroll">

<!-- BALANCE -->

<div class="balanceCard">

<div id="freeFundsLabel" style="font-size:10px;font-weight:900;color:#94a3b8;text-transform:uppercase;">
Wolne środki
</div>

<div style="font-size:42px;font-weight:900;margin-top:6px;">
<span id="balanceText">0.00</span> €
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:18px;">

<button onclick="openATM('deposit')"
class="mainBtn"
id="depositBtn"
style="background:#10b981;color:white;">
💵 WPŁAĆ
</button>

<button onclick="openATM('withdraw')"
class="mainBtn"
id="withdrawBtn"
style="background:#ef4444;color:white;">
💸 WYDAJ
</button>

</div>

</div>

<!-- WATER -->

<div style="background:linear-gradient(90deg,#dbeafe,#cffafe);padding:18px;border-radius:24px;border:1px solid #bfdbfe;display:flex;justify-content:space-between;align-items:center;margin-top:16px;">

<div>

<div id="gardenWaterLabel" style="font-size:11px;font-weight:900;color:#0369a1;">
💧 Woda ogrodowa
</div>

<div id="waterPlantsLabel" style="font-size:10px;color:#64748b;margin-top:2px;">
Podlewaj rośliny
</div>

</div>

<div style="font-size:32px;font-weight:900;color:#0284c7;">
<span id="waterText">0</span>
</div>

</div>

<!-- GOALS -->

<div style="margin-top:22px;display:flex;justify-content:space-between;align-items:center;">

<div id="savingsGoalsLabel" style="font-size:12px;font-weight:900;color:#475569;text-transform:uppercase;">
Cele oszczędnościowe
</div>

<button onclick="openGoalModal()"
id="newGoalBtn"
style="background:#cffafe;color:#0891b2;border:none;padding:10px 14px;border-radius:999px;font-size:11px;font-weight:900;">
+ NOWY
</button>

</div>

<div id="goalsWrap" style="margin-top:14px;display:flex;flex-direction:column;gap:16px;"></div>

<!-- GARDEN -->

<div id="yourGardenLabel" style="margin-top:28px;font-size:12px;font-weight:900;color:#475569;text-transform:uppercase;">
🏡 Twój ogród
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px;" id="gardenWrap"></div>

<!-- SELEKCJA APKI (SOFT PROMPT) -->
<div id="notificationPermissionCard" style="display:none; background: linear-gradient(135deg, #fef08a 0%, #fef9c3 100%); padding: 18px; border-radius: 26px; border: 2px dashed #eab308; margin-top: 28px; text-align: center; box-shadow: 0 8px 20px rgba(234,179,8,0.15);">
    <div id="ntfPermissionTitle" style="font-size: 13px; font-weight: 900; color: #854d0e; text-transform: uppercase; letter-spacing: 0.5px;">🔔 POWIADOMIENIA APLIKACJI</div>
    <div id="ntfPermissionDesc" style="font-size: 11px; color: #a16207; margin-top: 6px; margin-bottom: 14px; font-weight: 600; line-height: 1.4;">Czy chcesz aktywować powiadomienia dymkowe dla zmian konta i zbiorów z ogrodu?</div>
    
    <div style="display:flex; flex-direction:column; gap: 8px;">
       <button onclick="requestNotificationPermission()" id="ntfPermissionBtn" class="mainBtn" style="background: #eab308; color: white; padding: 10px; font-size: 12px; box-shadow: 0 4px 12px rgba(234,179,8,0.2);">TAK, CHCĘ!</button>
       
       <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 8px;">
          <button onclick="denyInternalNotifications()" id="ntfDenyBtn" class="mainBtn" style="background: #e2e8f0; color: #475569; padding: 10px; font-size: 11px;">NIE, DZIĘKUJĘ</button>
          <button onclick="remindInAWeek()" id="ntfRemindBtn" class="mainBtn" style="background: #cbd5e1; color: #1e293b; padding: 10px; font-size: 11px;">PRZYPOMNIJ ZA TYDZIEŃ</button>
       </div>
    </div>
</div>

<!-- CENTRUM POWIADOMIEN -->
<div style="margin-top:28px; display:flex; justify-content:space-between; align-items:center;">
    <div id="appNotificationsLabel" style="font-size:12px; font-weight:900; color:#475569; text-transform:uppercase;">
        🔔 Centrum powiadomień
    </div>
    <button onclick="clearAllNotifications()" id="clearAllNtfBtn" style="background:none; border:none; color:#ef4444; font-size:10px; font-weight:900; cursor:pointer; text-transform:uppercase; letter-spacing:0.5px;">
        WYCZYŚĆ
    </button>
</div>

<!-- STATUS POWIADOMIEN ORAZ PRZYCISK TESTU -->
<div style="display:flex; flex-direction:column; gap:8px; margin-top:10px;">
    <div onclick="toggleNotificationsManually()" id="ntfStatusBadge" style="padding: 12px 16px; border-radius: 18px; font-size: 12px; font-weight: 800; display: flex; align-items: center; justify-content: space-between; cursor: pointer; transition: 0.2s; border: 1px solid #cbd5e1; background: #f1f5f9;">
        <span id="ntfStatusText">Stan powiadomień...</span>
        <span id="ntfStatusPluska" style="font-size: 16px;">⚪</span>
    </div>
    
    <button onclick="triggerNotificationTest()" id="testNtfBtn" class="mainBtn" style="background: #0284c7; color: white; padding: 10px; font-size: 11px; box-shadow: 0 4px 10px rgba(2,132,199,0.15);">
        🧪 TESTUJ POWIADOMIENIA
    </button>
</div>

<div id="appNotificationsWrap" style="margin-top:10px; margin-bottom: 20px; display:flex; flex-direction:column; gap:10px; background: rgba(248, 250, 252, 0.7); padding: 14px; border-radius: 24px; border: 1px solid #e2e8f0; max-height: 220px; overflow-y: auto;">
</div>

</div>

<!-- ATM MODAL -->

<div class="modal" id="atmModal">

<div class="modalBox">

<div style="display:flex;justify-content:space-between;align-items:center;">

<div id="atmTitle" style="font-size:18px;font-weight:900;">
🏧 Operacja
</div>

<button onclick="closeATM()"
style="border:none;background:none;font-size:24px;">
✕
</button>

</div>

<div style="margin-top:18px;">

<input type="number" id="atmAmount" placeholder="Kwota €">

</div>

<div style="margin-top:14px;">

<input type="text" id="atmReason" placeholder="Powód / marzenie / jedzenie (opcjonalnie)">

</div>

<div style="margin-top:18px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">

<button onclick="closeATM()"
class="mainBtn"
id="atmCancelBtn"
style="background:#e2e8f0;">
Anuluj
</button>

<button onclick="confirmATM()"
class="mainBtn"
id="atmConfirmBtn"
style="background:#06b6d4;color:white;">
Zatwierdź
</button>

</div>

</div>

</div>

<!-- GOAL MODAL -->

<div class="modal" id="goalModal">

<div class="modalBox">

<div style="display:flex;justify-content:space-between;align-items:center;">

<div id="newGoalTitle" style="font-size:18px;font-weight:900;">
🎯 Nowy cel
</div>

<button onclick="closeGoalModal()"
style="border:none;background:none;font-size:24px;">
✕
</button>

</div>

<div style="margin-top:16px;">
<input type="text" id="goalName" placeholder="Np. Telefon">
</div>

<div style="margin-top:14px;">
<input type="number" id="goalTarget" placeholder="Kwota docelowa €">
</div>

<div style="margin-top:18px;">
<button onclick="createGoal()"
class="mainBtn"
id="createGoalBtn"
style="background:#10b981;color:white;width:100%;">
Stwórz cel
</button>
</div>

</div>

</div>

<!-- HISTORY MODAL -->

<div class="modal" id="historyModal">

<div class="modalBox">

<div style="display:flex;justify-content:space-between;align-items:center;">

<div id="historyTitle" style="font-size:18px;font-weight:900;">
📊 Historia
</div>

<button onclick="closeHistory()"
style="border:none;background:none;font-size:24px;">
✕
</button>

</div>

<div id="historyWrap"
style="margin-top:16px;display:flex;flex-direction:column;gap:10px;"></div>

</div>

</div>

<!-- LANGUAGE MODAL -->

<div class="modal" id="langModal">

<div class="modalBox">

<div style="display:flex;justify-content:space-between;align-items:center;">

<div id="langModalTitle" style="font-size:18px;font-weight:900;">
🌐 Język / Language / Sprache
</div>

<button onclick="closeLangModal()"
style="border:none;background:none;font-size:24px;">
✕
</button>

</div>

<div style="margin-top:20px;display:flex;flex-direction:column;gap:12px;">

<select id="langSelect" onchange="changeLanguage(this.value)">
</select>

</div>

<div style="margin-top:20px;">

<button onclick="closeLangModal()"
class="mainBtn"
id="langCloseBtn"
style="background:#06b6d4;color:white;width:100%;">
OK
</button>

</div>

</div>

</div>

<!-- TEST ALERTA POWIADOMIENIA MODAL -->
<div class="modal" id="testNtfModal">
    <div class="modalBox" style="text-align: center; max-width: 340px;">
        <div style="font-size: 44px; margin-bottom: 10px;">🚀</div>
        <div id="testModalTitle" style="font-size: 16px; font-weight: 900; color: #0f172a; line-height: 1.4;">
            Wysłaliśmy Ci testowe powiadomienie!
        </div>
        <div id="testModalDesc" style="font-size: 12px; color: #64748b; margin-top: 8px; margin-bottom: 18px; font-weight: 600;">
            Sprawdź, czy dotarło i czy poprawnie wyświetliło się w aplikacji oraz na Twoim urządzeniu.
        </div>
        <button onclick="closeTestNtfModal()" class="mainBtn" style="background: #10b981; color: white; width: 100%; padding: 12px;">
            OK
        </button>
    </div>
</div>

</div>

<script>

let atmMode="deposit";

let data={
lang:"pl",
balance:0,
water:0,
goals:[],
history:[],
notificationsLog:[], 
expandedNotifications: {}, 
