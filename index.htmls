goalBtnAdd: "💧 Hinzufügen",
goalBtnBuy: "🛍️ Kaufen",
ntfTitleSystem: "Blasengarten 🫧",
ntfDeposit: "Erfolgreich eingezahlt: +",
ntfWithdraw: "Erfolgreich ausgegeben: -",
ntfWithdrawFor: " für: ",
ntfNewGoal: "Neues Ziel hinzugefügt: ",
ntfGoalAdded: "Eingezahlt für den Traum ",
ntfGoalSuccess: "🎉 Ziel erreicht! Gekauft: ",
ntfHarvest: "🌱 Pflanze ausgewachsen! Ernte erfolgreich.",
ntfPermissionTitle: "🔔 APP-BENACHRICHTIGUNGEN",
ntfPermissionDesc: "Möchten Sie Push-Benachrichtigungen für Kontoänderungen und Gartenerträge aktivieren?",
ntfPermissionBtn: "JA, ERLAUBEN!",
ntfDenyBtn: "NEIN, DANKE",
ntfRemindBtn: "IN EINER WOCHE ERINNERN",
appNotificationsLabel: "🔔 Benachrichtigungscenter",
clearAllBtn: "LEEREN",
noNotifications: "Keine Meldungen",
statusActive: "Meldungen: AKTIVIERT",
statusDisabled: "Meldungen: DEAKTIVIERT",
showMore: "Mehr anzeigen",
showLess: "Weniger anzeigen",
testBtn: "🧪 BENACHRICHTIGUNGSTEST",
testModalTitle: "Test-Benachrichtigung gesendet!",
testModalDesc: "Prüfen Sie, ob sie angekommen ist und in der App sowie auf Ihrem Gerät korrekt angezeigt wird.",
testSuccessMsg: "🧪 Benachrichtigungstest erfolgreich! Das Blasen- und Alarmsystem im Blasengarten funktioniert einwandfrei und stabil.",
langNames: {
pl: "Polnisch (Polski)",
en: "Englisch (English)",
de: "Deutsch (Deutsch)"
}
}
};

function processNotification(message) {
    const t = translations[data.lang];
    const now = new Date();
    const timeStr = now.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});

    if(!data.notificationsLog) data.notificationsLog = [];
    
    data.notificationsLog.unshift({ id: Date.now() + Math.random(), text: message, time: timeStr });
    
    if(data.notificationsLog.length > 30) data.notificationsLog.pop();

    if (data.notificationChoice === "granted" && "Notification" in window && Notification.permission === "granted") {
        new Notification(t.ntfTitleSystem, {
            body: message,
            icon: "https://cdn-icons-png.flaticon.com/512/2621/2621415.png"
        });
    }
    
    renderAppNotifications();
    save();
}

// WYWOŁANIE TESTU POWIADOMIENIA
function triggerNotificationTest() {
    const t = translations[data.lang];
    
    // 1. Wysyłamy właściwe powiadomienie (wewnątrz i systemowo)
    processNotification(t.testSuccessMsg);
    
    // 2. Pokazujemy ładne okienko informacyjne
    document.getElementById("testNtfModal").style.display = "flex";
}

function closeTestNtfModal() {
    document.getElementById("testNtfModal").style.display = "none";
}

function toggleNtfExpand(id) {
    if(!data.expandedNotifications) data.expandedNotifications = {};
    data.expandedNotifications[id] = !data.expandedNotifications[id];
    renderAppNotifications();
    save();
}

function deleteOneNotification(id) {
    if(!data.notificationsLog) return;
    data.notificationsLog = data.notificationsLog.filter(ntf => ntf.id !== id);
    if(data.expandedNotifications && data.expandedNotifications[id]) {
        delete data.expandedNotifications[id];
    }
    renderAppNotifications();
    save();
}

function clearAllNotifications() {
    data.notificationsLog = [];
    data.expandedNotifications = {};
    renderAppNotifications();
    save();
}

function requestNotificationPermission() {
    data.notificationChoice = "granted";
    data.remindTimestamp = 0;
    save();

    if ("Notification" in window) {
        Notification.requestPermission().then(permission => {
            checkNotificationPermissionCard();
            updateStatusBadge();
        });
    } else {
        checkNotificationPermissionCard();
        updateStatusBadge();
    }
}

function denyInternalNotifications() {
    data.notificationChoice = "denied";
    data.remindTimestamp = 0;
    save();
    checkNotificationPermissionCard();
    updateStatusBadge();
}

function remindInAWeek() {
    data.notificationChoice = "remind";
    data.remindTimestamp = Date.now() + (7 * 24 * 60 * 60 * 1000); 
    save();
    checkNotificationPermissionCard();
    updateStatusBadge();
}

function toggleNotificationsManually() {
    if (data.notificationChoice === "granted") {
        data.notificationChoice = "denied";
    } else {
        data.notificationChoice = "granted";
        if ("Notification" in window) {
            Notification.requestPermission();
        }
    }
    data.remindTimestamp = 0;
    save();
    checkNotificationPermissionCard();
    updateStatusBadge();
}

function updateStatusBadge() {
    const badge = document.getElementById("ntfStatusBadge");
    const textEl = document.getElementById("ntfStatusText");
    const pluskaEl = document.getElementById("ntfStatusPluska");
    if (!badge || !textEl || !pluskaEl) return;
    
    const t = translations[data.lang];
    
    if (data.notificationChoice === "granted") {
        textEl.innerText = t.statusActive;
        pluskaEl.innerText = "🟢";
        badge.style.background = "#dcfce7";
        badge.style.borderColor = "#86efac";
        badge.style.color = "#166534";
    } else {
        textEl.innerText = t.statusDisabled;
        pluskaEl.innerText = "🔴";
        badge.style.background = "#fee2e2";
        badge.style.borderColor = "#fca5a5";
        badge.style.color = "#991b1b";
    }
}

function checkNotificationPermissionCard() {
    const card = document.getElementById("notificationPermissionCard");
    if (!card) return;
    
    if (data.notificationChoice === "unset") {
        card.style.display = "block";
        return;
    }
    
    if (data.notificationChoice === "remind") {
        if (Date.now() >= data.remindTimestamp) {
            data.notificationChoice = "unset";
            save();
            card.style.display = "block";
            return;
        }
    }
    
    card.style.display = "none";
}

function save(){
localStorage.setItem("bubbleGardenFull",JSON.stringify(data));
}

function load(){
const stored=localStorage.getItem("bubbleGardenFull");
if(stored){
data=JSON.parse(stored);
if(!data.lang) data.lang = "pl";
if(!data.notificationsLog) data.notificationsLog = [];
if(!data.expandedNotifications) data.expandedNotifications = {};
if(!data.notificationChoice) data.notificationChoice = "unset";
if(!data.remindTimestamp) data.remindTimestamp = 0;
}else{
save();
}
}

function resetApp(){
localStorage.removeItem("bubbleGardenFull");
location.reload();
}

function updateUI(){
const t = translations[data.lang];

document.getElementById("appTitle").innerText = t.appTitle;
document.getElementById("appSubtitle").innerText = t.appSubtitle;
document.getElementById("freeFundsLabel").innerText = t.freeFunds;
document.getElementById("depositBtn").innerText = t.deposit;
document.getElementById("withdrawBtn").innerText = t.withdraw;
document.getElementById("gardenWaterLabel").innerText = t.gardenWater;
document.getElementById("waterPlantsLabel").innerText = t.waterPlants;
document.getElementById("savingsGoalsLabel").innerText = t.savingsGoals;
document.getElementById("newGoalBtn").innerText = t.newGoal;
document.getElementById("yourGardenLabel").innerText = t.yourGarden;

document.getElementById("ntfPermissionTitle").innerText = t.ntfPermissionTitle;
document.getElementById("ntfPermissionDesc").innerText = t.ntfPermissionDesc;
document.getElementById("ntfPermissionBtn").innerText = t.ntfPermissionBtn;
document.getElementById("ntfDenyBtn").innerText = t.ntfDenyBtn;
document.getElementById("ntfRemindBtn").innerText = t.ntfRemindBtn;
document.getElementById("appNotificationsLabel").innerText = t.appNotificationsLabel;
document.getElementById("clearAllNtfBtn").innerText = t.clearAllBtn || "WYCZYŚĆ";
document.getElementById("testNtfBtn").innerText = t.testBtn;

document.getElementById("testModalTitle").innerText = t.testModalTitle;
document.getElementById("testModalDesc").innerText = t.testModalDesc;

document.getElementById("atmTitle").innerText = t.operation;
document.getElementById("atmCancelBtn").innerText = t.cancel;
document.getElementById("atmConfirmBtn").innerText = t.confirm;
document.getElementById("atmAmount").placeholder = t.atmAmountPlh;
document.getElementById("atmReason").placeholder = t.atmReasonPlh;

document.getElementById("newGoalTitle").innerText = t.newGoalTitle;
document.getElementById("goalName").placeholder = t.goalNamePlh;
document.getElementById("goalTarget").placeholder = t.goalTargetPlh;
document.getElementById("createGoalBtn").innerText = t.createGoalBtn;

document.getElementById("historyTitle").innerText = t.historyTitle;
document.getElementById("langModalTitle").innerText = t.langModalTitle;
document.getElementById("langCloseBtn").innerText = t.langCloseBtn;

document.getElementById("balanceText").innerText=data.balance.toFixed(2);
document.getElementById("waterText").innerText=data.water;

checkNotificationPermissionCard();
updateStatusBadge();
renderLangSelect();
renderGoals();
renderGarden();
renderHistory();
renderAppNotifications();

save();
}

function openLangModal(){
document.getElementById("langModal").style.display="flex";
}

function closeLangModal(){
document.getElementById("langModal").style.display="none";
}

function changeLanguage(langCode){
data.lang = langCode;
updateUI();
}

function renderLangSelect(){
const select = document.getElementById("langSelect");
const t = translations[data.lang];
select.innerHTML = `
<option value="pl" ${data.lang==='pl'?'selected':''}>${t.langNames.pl}</option>
<option value="en" ${data.lang==='en'?'selected':''}>${t.langNames.en}</option>
<option value="de" ${data.lang==='de'?'selected':''}>${t.langNames.de}</option>
`;
}

function openATM(type){
atmMode=type;
document.getElementById("atmModal").style.display="flex";
}

function closeATM(){
document.getElementById("atmModal").style.display="none";
}

function confirmATM(){
const t = translations[data.lang];
const amount=parseFloat(document.getElementById("atmAmount").value);
const reason=document.getElementById("atmReason").value;

if(isNaN(amount)||amount<=0)return;

const now=new Date();
const date=now.toLocaleDateString()+" "+now.toLocaleTimeString();

if(atmMode==="deposit"){
data.balance+=amount;
data.history.unshift({
type:"deposit",
text: t.histDeposit,
amount:amount,
date:date
});
processNotification(`${t.ntfDeposit}${amount.toFixed(2)} €`);
}else{
if(amount>data.balance){
alert(t.alertNoMoney);
return;
}
data.balance-=amount;
data.history.unshift({
type:"withdraw",
text:reason ? `${t.histWithdrawReason}${reason}` : t.histWithdrawDefault,
amount:amount,
date:date
});
const details = reason ? `${t.ntfWithdrawFor}"${reason}"` : "";
processNotification(`${t.ntfWithdraw}${amount.toFixed(2)} €${details}`);
}

document.getElementById("atmAmount").value="";
document.getElementById("atmReason").value="";
closeATM();
updateUI();
}

function openGoalModal(){
document.getElementById("goalModal").style.display="flex";
}

function closeGoalModal(){
document.getElementById("goalModal").style.display="none";
}

function createGoal(){
const t = translations[data.lang];
const name=document.getElementById("goalName").value;
const target=parseFloat(document.getElementById("goalTarget").value);

if(!name||isNaN(target)||target<=0)return;

data.goals.push({
id:Date.now(),
name:name,
target:target,
current:0
});

processNotification(`${t.ntfNewGoal}"${name}" (${target.toFixed(0)} €)`);
document.getElementById("goalName").value="";
document.getElementById("goalTarget").value="";
closeGoalModal();
updateUI();
}

function addToGoal(id){
const t = translations[data.lang];
const val=prompt(t.promptAddGoal);
const amount=parseFloat(val);

if(isNaN(amount)||amount<=0)return;
if(amount>data.balance){
alert(t.alertNoFunds);
return;
}

const goal=data.goals.find(g=>g.id===id);
goal.current+=amount;
data.balance-=amount;
data.water+=Math.max(1,Math.floor(amount/5));

data.history.unshift({
type:"goal",
text: `${t.histGoal}${goal.name}`,
amount:amount,
date:new Date().toLocaleString()
});

processNotification(`${t.ntfGoalAdded}"${goal.name}": +${amount.toFixed(2)} €`);
updateUI();
}

function buyGoal(id){
const t = translations[data.lang];
const goal=data.goals.find(g=>g.id===id);

if(goal.current<goal.target){
alert(t.alertLowSavings);
return;
}

goal.current-=goal.target;
data.history.unshift({
type:"buy",
text: `${t.histBuy}${goal.name}`,
amount:goal.target,
date:new Date().toLocaleString()
});

processNotification(`${t.ntfGoalSuccess}"${goal.name}" 🛍️`);
updateUI();
}

function removeGoal(id){
data.goals=data.goals.filter(g=>g.id!==id);
updateUI();
}

function renderGoals(){
const t = translations[data.lang];
const wrap=document.getElementById("goalsWrap");
wrap.innerHTML="";

if(data.goals.length===0){
wrap.innerHTML=`
<div style="background:white;border-radius:24px;padding:30px;text-align:center;color:#94a3b8;border:1px dashed #cbd5e1;">
${t.noGoals}
</div>
`;
return;
}

data.goals.forEach(goal=>{
const percent=Math.min(Math.round((goal.current/goal.target)*100),100);
let bubblesHTML="";

for(let i=0;i<8;i++){
const colors=["#38bdf8","#22c55e","#f472b6","#facc15","#a78bfa"];
bubblesHTML+=`
<div class="bubble" style="width:${6+Math.random()*10}px; height:${6+Math.random()*10}px; left:${Math.random()*100}%; bottom:-20px; background:${colors[Math.floor(Math.random()*colors.length)]}; animation-duration:${3+Math.random()*3}s; animation-delay:${Math.random()*2}s;"></div>
`;
}

const top=100-percent;
const done=percent>=100;

wrap.innerHTML+=`
<div class="goalCard">
<div style="font-weight:900;font-size:16px;text-align:center;">${goal.name}</div>
<div style="font-size:11px;color:#64748b;text-align:center;margin-top:4px;">${goal.current.toFixed(0)} € z ${goal.target.toFixed(0)} €</div>
<div style="width:170px; height:170px; margin:16px auto; border-radius:999px; background:#f8fafc; padding:6px; position:relative; overflow:hidden; border:5px solid #67e8f9;">
<div style="width:100%; height:100%; border-radius:999px; overflow:hidden; position:relative; background:white;">
<div class="wave" style="top:${top}%; background:linear-gradient(to bottom, ${done ? "#34d399" : "#34d399"}, ${done ? "#10b981" : "#2563eb"});"></div>
${bubblesHTML}
<div style="position:absolute; inset:0; display:flex; justify-content:center; align-items:center; font-size:34px; font-weight:900; color:white; z-index:5; text-shadow:0 2px 8px rgba(0,0,0,.2);">${percent}%</div>
</div>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
<button onclick="addToGoal(${goal.id})" class="mainBtn" style="background:#cffafe;color:#0891b2;font-size:11px;">${t.goalBtnAdd}</button>
<button onclick="buyGoal(${goal.id})" class="mainBtn" style="background:#10b981;color:white;font-size:11px;">${t.goalBtnBuy}</button>
<button onclick="removeGoal(${goal.id})" class="mainBtn" style="background:#fee2e2;color:#ef4444;font-size:11px;">✕</button>
</div>
</div>
`;
});
}

function renderGarden(){
const t = translations[data.lang];
const wrap=document.getElementById("gardenWrap");
wrap.innerHTML="";

data.garden.forEach((slot,index)=>{
if(!slot.planted){
wrap.innerHTML+=`
<div class="slot" onclick="plantSeed(${index})">
<div style="font-size:52px;">🟤</div>
<div style="margin-top:10px;font-weight:900;font-size:12px;">${t.emptySoil}</div>
</div>
`;
}else{
wrap.innerHTML+=`
<div class="slot" onclick="waterPlant(${index})">
<div style="font-size:52px;">${slot.emoji}</div>
<div style="margin-top:10px;font-weight:900;font-size:12px;">${slot.translatedName || slot.name}</div>
<div style="width:100%;height:10px;background:#e2e8f0;border-radius:999px;margin-top:10px;overflow:hidden;">
<div style="width:${slot.progress}%; height:100%; background:#10b981;"></div>
</div>
<div style="font-size:11px;margin-top:6px;color:#64748b;">${slot.progress}%</div>
</div>
`;
}
});
}

function plantSeed(index){
const t = translations[data.lang];
if(data.inventory.length===0){
alert(t.alertNoSeeds);
return;
}

const emoji=data.inventory.shift();
let name="Roślina";
let transName = t.plantPlant;

if(emoji==="🥕") { name="Marchewka"; transName = t.plantCarrot; }
if(emoji==="🍅") { name="Pomidor"; transName = t.plantTomato; }
if(emoji==="🧅") { name="Cebula"; transName = t.plantOnion; }
if(emoji==="🍎") { name="Jabłoń"; transName = t.plantApple; }

data.garden[index]={
planted:true,
emoji:emoji,
name:name,
translatedName: transName,
progress:0
};
updateUI();
}

function waterPlant(index){
const t = translations[data.lang];
const slot=data.garden[index];

if(!slot.planted)return;
if(data.water<=0){
alert(t.alertNoWater);
return;
}

data.water-=1;
slot.progress+=10;

if(slot.progress>=100){
slot.progress=100;
data.inventory.push("🥕");
processNotification(t.ntfHarvest);
setTimeout(()=>{
data.garden[index]={planted:false};
updateUI();
},500);
}
updateUI();
}

function openHistory(){
document.getElementById("historyModal").style.display="flex";
}

function closeHistory(){
document.getElementById("historyModal").style.display="none";
}

function renderHistory(){
const t = translations[data.lang];
const wrap=document.getElementById("historyWrap");
wrap.innerHTML="";

if(data.history.length===0){
wrap.innerHTML=`<div style="text-align:center;color:#94a3b8;padding:20px;">${t.noHistory}</div>`;
return;
}

data.history.forEach(item=>{
wrap.innerHTML+=`
<div class="histItem">
<div>
<div style="font-weight:900;font-size:13px;">${item.text}</div>
<div style="font-size:10px;color:#64748b;margin-top:3px;">${item.date}</div>
</div>
<div style="font-weight:900; font-size:16px; color:${item.type==="deposit"?"#10b981":"#ef4444"};">${item.type==="deposit"?"+":"-"}${item.amount.toFixed(2)} €</div>
</div>
`;
});
}

function renderAppNotifications() {
    const t = translations[data.lang];
    const wrap = document.getElementById("appNotificationsWrap");
    if(!wrap) return;

    wrap.innerHTML = "";
    
    if(!data.notificationsLog || data.notificationsLog.length === 0) {
        wrap.innerHTML = `<div style="text-align:center; color:#94a3b8; font-size:11px; padding:10px;">${t.noNotifications}</div>`;
        return;
    }

    if(!data.expandedNotifications) data.expandedNotifications = {};

    data.notificationsLog.forEach(ntf => {
        const isLong = ntf.text.length > 60;
        const isExpanded = data.expandedNotifications[ntf.id] || false;
        
        let displayText = ntf.text;
        let toggleBtnHTML = "";

        if (isLong) {
            if (!isExpanded) {
                displayText = ntf.text.substring(0, 55) + "... ";
                toggleBtnHTML = `<button onclick="toggleNtfExpand(${ntf.id})" style="background:none; border:none; color:#06b6d4; font-size:10px; font-weight:800; cursor:pointer; padding:0; margin-left:4px; text-decoration:underline; display:inline-block;">${t.showMore || "Pokaż więcej"}</button>`;
            } else {
                displayText = ntf.text + " ";
                toggleBtnHTML = `<button onclick="toggleNtfExpand(${ntf.id})" style="background:none; border:none; color:#64748b; font-size:10px; font-weight:800; cursor:pointer; padding:0; margin-left:4px; text-decoration:underline; display:inline-block;">${t.showLess || "Pokaż mniej"}</button>`;
            }
        }

        wrap.innerHTML += `
            <div style="background:white; border-radius:14px; padding:10px 14px; display:flex; justify-content:space-between; align-items:start; border:1px solid #e2e8f0; font-size:12px; font-weight:700; color:#334155;">
                <div style="flex:1; padding-right:8px; line-height: 1.4; word-break: break-word;">
                    <span>${displayText}</span>${toggleBtnHTML}
                </div>
                <div style="display:flex; align-items:center; gap:10px; flex-shrink:0; margin-top: 1px;">
                    <div style="font-size:10px; color:#94a3b8; font-weight:500;">${ntf.time}</div>
                    <button onclick="deleteOneNotification(${ntf.id})" style="background:none; border:none; color:#cbd5e1; font-weight:900; font-size:12px; cursor:pointer; padding:2px 4px; transition:0.2s;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#cbd5e1'">✕</button>
                </div>
            </div>
        `;
    });
}

load();
updateUI();

</script>

</body>
</html>
