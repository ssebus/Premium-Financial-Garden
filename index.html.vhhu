<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Bąbelkowy Ogród Finansowy</title>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>

body{
margin:0;
font-family:Arial,sans-serif;
background:linear-gradient(135deg,#dff7ff,#ffffff,#eafff3);
height:100vh;
overflow:hidden;
}

.app{
width:100%;
height:100%;
display:flex;
justify-content:center;
align-items:center;
}

.phone{
width:390px;
height:95vh;
background:white;
border-radius:35px;
overflow:hidden;
box-shadow:0 0 40px rgba(0,0,0,0.15);
display:flex;
flex-direction:column;
}

.top{
background:linear-gradient(90deg,#2bc7ff,#22d28f);
padding:18px;
color:white;
display:flex;
justify-content:space-between;
align-items:center;
font-weight:bold;
}

.content{
flex:1;
overflow-y:auto;
padding:15px;
}

.card{
background:white;
border-radius:24px;
padding:16px;
margin-bottom:15px;
box-shadow:0 0 10px rgba(0,0,0,0.08);
}

button{
border:none;
border-radius:14px;
padding:12px;
font-weight:bold;
cursor:pointer;
}

.main{
background:linear-gradient(90deg,#2bc7ff,#22d28f);
color:white;
width:100%;
margin-top:10px;
}

.small{
background:#eef9ff;
width:100%;
margin-top:8px;
}

input{
width:100%;
padding:12px;
border-radius:12px;
border:1px solid #ccc;
margin-top:10px;
box-sizing:border-box;
}

.hidden{
display:none;
}

.row{
display:flex;
gap:10px;
}

.goal{
background:#f5fbff;
padding:14px;
border-radius:20px;
margin-top:12px;
}

.progress{
height:14px;
background:#ddd;
border-radius:10px;
overflow:hidden;
margin-top:8px;
}

.bar{
height:100%;
background:linear-gradient(90deg,#2bc7ff,#22d28f,#ff72dd,#ffe066);
}

.history{
background:#f7f7f7;
padding:10px;
border-radius:12px;
margin-top:8px;
font-size:14px;
}

.garden{
display:grid;
grid-template-columns:1fr 1fr;
gap:12px;
}

.plant{
background:#f7fff7;
height:140px;
border-radius:18px;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
font-size:14px;
cursor:pointer;
}

.authBox{
padding:25px;
}

</style>
</head>
<body>

<div class="app">
<div class="phone">

<div id="authPanel" class="content authBox">

<h2>🫧 Logowanie</h2>

<div class="row">

<button
type="button"
class="small"
onclick="openLogin()">
Logowanie
</button>

<button
type="button"
class="small"
onclick="openRegister()">
Rejestracja
</button>

</div>

<div id="loginSection">

<input
id="loginEmail"
type="email"
placeholder="Email">

<input
id="loginPassword"
type="password"
placeholder="Hasło">

<button
type="button"
class="main"
onclick="loginUser()">
Zaloguj się
</button>

</div>

<div id="registerSection" class="hidden">

<input
id="registerEmail"
type="email"
placeholder="Email">

<input
id="registerPassword"
type="password"
placeholder="Hasło">

<button
type="button"
class="main"
onclick="registerUser()">
Stwórz konto
</button>

</div>

<p id="authText"></p>

</div>

<div id="appPanel" class="hidden">

<div class="top">

<div>
🫧 Bąbelkowy Ogród
</div>

<button onclick="logoutUser()">
Wyloguj
</button>

</div>

<div class="content">

<div class="card">

<h3>💰 Stan konta</h3>

<h1 id="balance">
0 €
</h1>

<div class="row">

<button
class="main"
onclick="depositMoney()">
Wpłać
</button>

<button
class="main"
onclick="withdrawMoney()">
Wypłać
</button>

</div>

<button
class="small"
onclick="buySomething()">
Kupuję / Wydaję
</button>

</div>

<div class="card">

<h3>🎯 Marzenia</h3>

<input
id="goalName"
placeholder="Nazwa marzenia">

<input
id="goalPrice"
type="number"
placeholder="Cena">

<button
class="main"
onclick="addGoal()">
Dodaj marzenie
</button>

<div id="goals"></div>

</div>

<div class="card">

<h3>🌱 Ogród</h3>

<p>
💧 Woda:
<span id="water">0</span>
</p>

<div class="garden">

<div class="plant" onclick="growPlant(0)">
<div id="p0">🟤</div>
<div id="n0">Puste</div>
</div>

<div class="plant" onclick="growPlant(1)">
<div id="p1">🟤</div>
<div id="n1">Puste</div>
</div>

<div class="plant" onclick="growPlant(2)">
<div id="p2">🟤</div>
<div id="n2">Puste</div>
</div>

<div class="plant" onclick="growPlant(3)">
<div id="p3">🟤</div>
<div id="n3">Puste</div>
</div>

</div>

</div>

<div class="card">

<h3>📜 Historia</h3>

<div id="history"></div>

</div>

</div>
</div>

</div>
</div>

<script>

const SUPABASE_URL = "TUTAJ_SUPABASE_URL";
const SUPABASE_KEY = "TUTAJ_SUPABASE_ANON_KEY";

const sb = supabase.createClient(
SUPABASE_URL,
SUPABASE_KEY
);

let state = {
balance:0,
water:0,
goals:[],
history:[],
plants:[
{emoji:"🟤",name:"Puste",progress:0},
{emoji:"🟤",name:"Puste",progress:0},
{emoji:"🟤",name:"Puste",progress:0},
{emoji:"🟤",name:"Puste",progress:0}
]
};

function openLogin(){

document.getElementById("loginSection")
.classList.remove("hidden");

document.getElementById("registerSection")
.classList.add("hidden");

}

function openRegister(){

document.getElementById("registerSection")
.classList.remove("hidden");

document.getElementById("loginSection")
.classList.add("hidden");

}

async function registerUser(){

const email =
document.getElementById("registerEmail").value;

const password =
document.getElementById("registerPassword").value;

if(!email || !password){

document.getElementById("authText")
.innerText = "Wpisz email i hasło";

return;
}

const { error } =
await sb.auth.signUp({
email: email,
password: password
});

if(error){

document.getElementById("authText")
.innerText = error.message;

}else{

document.getElementById("authText")
.innerText = "Konto utworzone!";

}

}

async function loginUser(){

const email =
document.getElementById("loginEmail").value;

const password =
document.getElementById("loginPassword").value;

if(!email || !password){

document.getElementById("authText")
.innerText = "Wpisz email i hasło";

return;
}

const { error } =
await sb.auth.signInWithPassword({
email: email,
password: password
});

if(error){

document.getElementById("authText")
.innerText = error.message;

return;
}

document.getElementById("authPanel")
.classList.add("hidden");

document.getElementById("appPanel")
.classList.remove("hidden");

loadLocal();
renderApp();

}

async function logoutUser(){

await sb.auth.signOut();

location.reload();

}

function saveLocal(){

localStorage.setItem(
"bubbleGardenSave",
JSON.stringify(state)
);

}

function loadLocal(){

const saved =
localStorage.getItem("bubbleGardenSave");

if(saved){

state = JSON.parse(saved);

}

}

function renderApp(){

document.getElementById("balance")
.innerText =
state.balance.toFixed(2)+" €";

document.getElementById("water")
.innerText = state.water;

const goalsBox =
document.getElementById("goals");

goalsBox.innerHTML = "";

state.goals.forEach((g,index)=>{

const percent =
Math.min(100,(g.saved/g.target)*100);

goalsBox.innerHTML += `

<div class="goal">

<b>${g.name}</b><br>

${g.saved.toFixed(2)} €
/
${g.target.toFixed(2)} €

<div class="progress">
<div class="bar"
style="width:${percent}%">
</div>
</div>

<button
class="small"
onclick="addSavings(${index})">
Dodaj oszczędności
</button>

<button
class="small"
onclick="buyGoal(${index})">
Kupuję marzenie
</button>

</div>

`;

});

const hist =
document.getElementById("history");

hist.innerHTML = "";

state.history.forEach(h=>{

hist.innerHTML += `
<div class="history">${h}</div>
`;

});

for(let i=0;i<4;i++){

document.getElementById("p"+i)
.innerText =
state.plants[i].emoji;

document.getElementById("n"+i)
.innerText =
state.plants[i].name+
" "+
state.plants[i].progress+"%";

}

}

function addGoal(){

const name =
document.getElementById("goalName").value;

const target =
parseFloat(
document.getElementById("goalPrice").value
);

if(!name || !target) return;

state.goals.push({
name:name,
target:target,
saved:0
});

saveLocal();
renderApp();

}

function depositMoney(){

const amount =
parseFloat(prompt("Ile wpłacić?"));

if(!amount) return;

state.balance += amount;

state.history.unshift(
new Date().toLocaleString()+
" ➕ Wpłata "+
amount+"€"
);

saveLocal();
renderApp();

}

function withdrawMoney(){

const amount =
parseFloat(prompt("Ile wypłacić?"));

const text =
prompt("Na co wydajesz?");

if(!amount) return;

state.balance -= amount;

state.history.unshift(
new Date().toLocaleString()+
" ➖ Wypłata "+
amount+"€ "+
(text || "")
);

saveLocal();
renderApp();

}

function addSavings(index){

const amount =
parseFloat(
prompt("Ile oszczędności dodać?")
);

if(!amount) return;

if(amount > state.balance){

alert("Brak pieniędzy");
return;

}

state.balance -= amount;

state.goals[index].saved += amount;

state.water += 1;

state.history.unshift(
new Date().toLocaleString()+
" 💧 "+
amount+
"€ wpłacono na marzenie "+
state.goals[index].name
);

saveLocal();
renderApp();

}

function buyGoal(index){

if(
state.goals[index].saved <
state.goals[index].target
){

alert("Za mało pieniędzy");
return;

}

state.history.unshift(
new Date().toLocaleString()+
" 🛍️ Wydano na marzenie "+
state.goals[index].name+
" "+
state.goals[index].target+
"€"
);

state.goals.splice(index,1);

saveLocal();
renderApp();

}

function buySomething(){

const what =
prompt("Co kupujesz?");

const amount =
parseFloat(
prompt("Ile kosztuje?")
);

if(!amount) return;

state.balance -= amount;

state.history.unshift(
new Date().toLocaleString()+
" 🛒 Kupiono "+
what+
" za "+
amount+
"€"
);

saveLocal();
renderApp();

}

function growPlant(index){

if(state.plants[index].progress >= 100){

state.plants[index] = {
emoji:"🌻",
name:"Nowa roślinka",
progress:0
};

saveLocal();
renderApp();

return;

}

if(state.water <= 0){

alert("Brak wody");
return;

}

state.water -= 1;

if(
state.plants[index].name === "Puste"
){

state.plants[index] = {
emoji:"🥕",
name:"Marchewka",
progress:10
};

}else{

state.plants[index].progress += 10;

}

saveLocal();
renderApp();

}

sb.auth.getSession().then(({data})=>{

if(data.session){

document.getElementById("authPanel")
.classList.add("hidden");

document.getElementById("appPanel")
.classList.remove("hidden");

loadLocal();
renderApp();

}

});

</script>

</body>
</html>
